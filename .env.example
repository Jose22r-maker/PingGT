# Configuración de la aplicación PingGT

# URL donde está alojada la aplicación
# Ejemplo: http://localhost:3000 en desarrollo
APP_URL="http://localhost:3000"

# Puerto del servidor (opcional, por defecto 3000)
PORT=3000

# Modo de desarrollo (opcional)
NODE_ENV=development

# ===== Supabase Configuration =====
# URL de tu proyecto Supabase
SUPABASE_URL="https://your-project.supabase.co"

# Clave anónima de Supabase (publicable)
SUPABASE_ANON_KEY="your-anon-key"

# Clave de servicio de Supabase (solo servidor)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
